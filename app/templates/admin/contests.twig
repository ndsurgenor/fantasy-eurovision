{% extends 'admin/base.twig' %}

{% block page_title %}Contests{% endblock %}

{% block content %}
    <div class="flex items-center justify-between mb-6">
        <div>
            <h2 class="text-base text-gray-800">All Contests</h2>
            <p class="text-sm text-gray-500 mt-0.5">Click a contest title to manage it.</p>
        </div>
        <form method="POST" action="/admin/contests/new">
            <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg text-sm transition">
                + New Contest
            </button>
        </form>
    </div>

    {% if contests %}
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide border-b border-gray-200">
                        <th class="px-4 py-3 text-left">Title</th>
                        <th class="px-4 py-3 text-left">Year</th>
                        <th class="px-4 py-3 text-left">Status</th>
                        <th class="px-4 py-3 text-center">Active</th>
                        <th class="px-4 py-3 text-center">Groups</th>
                        <th class="px-4 py-3 text-center">Countries</th>
                        <th class="px-4 py-3 text-center">Entries</th>
                        <th class="px-4 py-3 text-left">Closing Date</th>
                        <th class="px-4 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for c in contests %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3 font-medium text-indigo-600 hover:text-indigo-800">
                                <a href="/admin/contests/{{ c.id }}">{{ c.name }}</a>
                            </td>
                            <td class="px-4 py-3 text-gray-600">{{ c.year }}</td>
                            <td class="px-4 py-3">
                                <span class="text-xs font-semibold px-2 py-0.5 rounded-full
                                    {% if c.status == 'setup' %}bg-gray-100 text-gray-600
                                    {% elseif c.status == 'open' %}bg-green-100 text-green-700
                                    {% elseif c.status == 'closed' %}bg-amber-100 text-amber-700
                                    {% else %}bg-blue-100 text-blue-700{% endif %}">
                                    {{ c.status|capitalize }}
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                {% if c.is_active %}
                                    <span class="inline-block w-3 h-3 rounded-full bg-emerald-500" title="Active"></span>
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-center text-gray-500">{{ c.group_count }}</td>
                            <td class="px-4 py-3 text-center text-gray-500">{{ c.country_count }}</td>
                            <td class="px-4 py-3 text-center text-gray-500">{{ c.entry_count }}</td>
                            <td class="px-4 py-3 text-gray-500">{{ c.launch_date ?? '—' }}</td>
                            <td class="px-4 py-3 text-right">
                                <a href="/admin/contests/{{ c.id }}"
                                   class="text-xs text-indigo-600 hover:text-indigo-800 font-medium mr-3">Manage</a>
                                <form method="POST" action="/admin/contests/duplicate" class="inline"
                                      onsubmit="return confirm('Duplicate {{ c.name }}? Groups and countries will be copied (entries and scores will not).')">
                                    <input type="hidden" name="source_contest_id" value="{{ c.id }}">
                                    <button type="submit" class="text-xs text-slate-500 hover:text-slate-700 font-medium">
                                        Duplicate
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="bg-white border border-gray-200 rounded-xl p-8 text-center shadow-sm">
            <p class="text-gray-400 text-sm mb-4">No contests yet.</p>
            <form method="POST" action="/admin/contests/new">
                <button type="submit"
                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-5 rounded-lg text-sm transition">
                    Create Your First Contest
                </button>
            </form>
        </div>
    {% endif %}
{% endblock %}
