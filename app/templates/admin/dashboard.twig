{% extends 'admin/base.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
            <p class="text-3xl font-bold text-indigo-600">{{ stats.players }}</p>
            <p class="text-gray-500 text-sm mt-1">Players</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
            <p class="text-3xl font-bold text-indigo-600">{{ stats.entries }}</p>
            <p class="text-gray-500 text-sm mt-1">Entries</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
            <p class="text-3xl font-bold text-indigo-600">{{ stats.countries }}</p>
            <p class="text-gray-500 text-sm mt-1">Countries</p>
        </div>
        <div class="bg-white border border-gray-200 rounded-xl p-4 text-center shadow-sm">
            <p class="text-3xl font-bold text-indigo-600">{{ stats.groups }}</p>
            <p class="text-gray-500 text-sm mt-1">Groups</p>
        </div>
    </div>

    <h2 class="text-sm text-gray-500 uppercase tracking-wider mb-3">Setup Checklist</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/admin/contest"
           class="bg-white border border-gray-200 hover:border-indigo-400 rounded-xl p-5 shadow-sm transition group">
            <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600 transition mb-1">Contest Settings</h3>
            <p class="text-gray-500 text-sm">Year, name, budget limit and status.</p>
        </a>
        <a href="/admin/groups"
           class="bg-white border border-gray-200 hover:border-indigo-400 rounded-xl p-5 shadow-sm transition group">
            <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600 transition mb-1">Groups</h3>
            <p class="text-gray-500 text-sm">Manage semi-final groups and wildcards.</p>
        </a>
        <a href="/admin/countries"
           class="bg-white border border-gray-200 hover:border-indigo-400 rounded-xl p-5 shadow-sm transition group">
            <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600 transition mb-1">Countries</h3>
            <p class="text-gray-500 text-sm">Add countries with prices and running order.</p>
        </a>
        <a href="/admin/scores"
           class="bg-white border border-gray-200 hover:border-indigo-400 rounded-xl p-5 shadow-sm transition group">
            <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600 transition mb-1">Enter Scores</h3>
            <p class="text-gray-500 text-sm">Input final points for each country.</p>
        </a>
    </div>
{% endblock %}
