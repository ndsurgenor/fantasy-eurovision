{% extends 'admin/base.twig' %}

{% block page_title %}Countries Catalogue{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        {# Form #}
        <div>
            <h2 class="text-base text-gray-700 mb-3">
                {{ edit_entry ? 'Edit Country' : 'Add Country' }}
            </h2>

            <form method="POST" action="/admin/countries" enctype="multipart/form-data"
                  class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm space-y-4">

                <input type="hidden" name="action" value="{{ edit_entry ? 'edit' : 'create' }}">
                {% if edit_entry %}
                    <input type="hidden" name="entry_id" value="{{ edit_entry.id }}">
                {% endif %}

                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Country Name</label>
                    <input type="text" id="name" name="name"
                           value="{{ edit_entry.name ?? '' }}"
                           required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="flag_image" class="block text-sm font-medium text-gray-700 mb-1">
                        Flag Image
                        {% if edit_entry %}
                            <span class="text-gray-400 font-normal">(leave blank to keep current)</span>
                        {% endif %}
                    </label>
                    {% if edit_entry and edit_entry.flag_image %}
                        <div class="mb-2">
                            <img src="/uploads/flags/{{ edit_entry.flag_image }}"
                                 alt="{{ edit_entry.name }}"
                                 class="h-8 w-auto rounded border border-gray-200">
                        </div>
                    {% endif %}
                    <input type="file" id="flag_image" name="flag_image"
                           accept="image/png,image/gif,image/jpeg,image/webp"
                           class="w-full text-sm text-gray-700 file:mr-3 file:py-1.5 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
                    <p class="text-xs text-gray-400 mt-1">PNG, GIF, JPEG or WebP accepted.</p>
                </div>

                <div class="flex gap-3 pt-1">
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-5 rounded-lg transition text-sm">
                        {{ edit_entry ? 'Update Country' : 'Add to Catalogue' }}
                    </button>
                    {% if edit_entry %}
                        <a href="/admin/countries"
                           class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-5 rounded-lg transition text-sm flex items-center">
                            Cancel
                        </a>
                    {% endif %}
                </div>
            </form>
        </div>

        {# Catalogue list #}
        <div>
            <h2 class="text-base text-gray-700 mb-3">
                Country Catalogue
                {% if countries %}<span class="text-gray-400 font-normal text-sm">({{ countries|length }})</span>{% endif %}
            </h2>

            {% if countries %}
                <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide border-b border-gray-200">
                                <th class="px-4 py-2 text-left">Country</th>
                                <th class="px-4 py-2 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {% for c in countries %}
                                <tr class="hover:bg-gray-50 transition">
                                    <td class="px-4 py-2 font-medium text-gray-800">
                                        <div class="flex items-center gap-2">
                                            {% if c.flag_image %}
                                                <img src="/uploads/flags/{{ c.flag_image }}" alt="{{ c.name }}" class="h-auto w-auto rounded-sm flex-shrink-0">
                                            {% endif %}
                                            {{ c.name }}
                                        </div>
                                    </td>
                                    <td class="px-4 py-2 text-right">
                                        <a href="/admin/countries?edit={{ c.id }}"
                                           class="text-xs text-indigo-600 hover:text-indigo-800 font-medium mr-3">Edit</a>
                                        <form method="POST" action="/admin/countries" class="inline"
                                              onsubmit="return confirm('Remove {{ c.name }} from the catalogue?')">
                                            <input type="hidden" name="action" value="delete">
                                            <input type="hidden" name="entry_id" value="{{ c.id }}">
                                            <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-gray-400 text-sm">No countries in the catalogue yet.</p>
            {% endif %}
        </div>

    </div>
{% endblock %}
