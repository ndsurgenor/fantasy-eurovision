{% extends 'admin/base.twig' %}

{% block page_title %}Enter Scores{% endblock %}

{% block content %}
    <p class="text-gray-500 text-sm mb-5">
        Enter the final Eurovision points for each country. Leave blank for countries that did not reach the final.
        Saving will recalculate all entry scores immediately.
    </p>

    <form method="POST" action="/admin/scores">
        <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden mb-5">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide border-b border-gray-200">
                        <th class="px-4 py-3 text-left">Country</th>
                        <th class="px-4 py-3 text-left hidden sm:table-cell">Group</th>
                        <th class="px-4 py-3 text-left hidden md:table-cell">Running Order</th>
                        <th class="px-4 py-3 text-right">Points</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for country in countries %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-4 py-3 font-medium text-gray-800">
                                {{ country.flag_emoji }} {{ country.name }}
                            </td>
                            <td class="px-4 py-3 text-gray-500 hidden sm:table-cell">{{ country.group_name }}</td>
                            <td class="px-4 py-3 text-gray-500 hidden md:table-cell">
                                {{ country.running_order ?? '—' }}
                            </td>
                            <td class="px-4 py-3 text-right">
                                <input type="number"
                                       name="scores[{{ country.id }}]"
                                       value="{{ country.final_score_raw ?? '' }}"
                                       min="0"
                                       class="w-24 border border-gray-300 rounded px-2 py-1 text-gray-900 text-right focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
                                       placeholder="—">
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-4 py-8 text-center text-gray-400">
                                No countries found.
                                <a href="/admin/countries" class="text-indigo-600 hover:underline">Add countries first.</a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition">
            Save Scores &amp; Recalculate
        </button>
    </form>
{% endblock %}
