{% extends 'admin/base.twig' %}

{% block page_title %}{{ contest.year }} — {{ contest.name }}{% endblock %}

{% block content %}

    {# Breadcrumb + actions #}
    <div class="flex items-center justify-between mb-5">
        <a href="/admin/contests" class="text-sm text-indigo-600 hover:text-indigo-800">← All Contests</a>
        <div class="flex items-center gap-2">
            <button type="submit" form="settings-form" name="_redirect" value=""
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg text-sm transition">
                Save
            </button>
            <button type="submit" form="settings-form" name="_redirect" value="1"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg text-sm transition">
                Save &amp; Close
            </button>
            <button type="button" onclick="document.getElementById('delete-dialog').showModal()"
                    {{ contest.status != 'setup' ? 'disabled title="Only contests in Setup status can be deleted"' }}
                    class="bg-rose-500 hover:bg-rose-600 text-white font-semibold py-2 px-4 rounded-lg text-sm transition disabled:opacity-40 disabled:cursor-not-allowed disabled:pointer-events-none">
                Delete Contest
            </button>
        </div>
    </div>

    {# Delete confirmation dialog #}
    <dialog id="delete-dialog"
            class="rounded-xl shadow-xl border border-gray-200 p-6 w-full max-w-md mx-auto mt-[20vh] backdrop:bg-black/40">
        <h2 class="text-base font-semibold text-gray-800 mb-2">Delete Contest</h2>
        <p class="text-sm text-gray-600 mb-1">
            This will permanently delete <strong>{{ contest.name }}</strong>, including all groups, countries, and player entries.
        </p>
        <p class="text-sm text-gray-600 mb-4">Type <strong>DELETE</strong> to confirm.</p>

        <input type="text" id="delete-confirm-input" placeholder="DELETE"
               oninput="document.getElementById('delete-confirm-btn').disabled = this.value !== 'DELETE'"
               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 mb-4
                      focus:outline-none focus:ring-2 focus:ring-red-400 focus:border-transparent">

        <form method="POST" action="/admin/contests/{{ contest.id }}">
            <input type="hidden" name="_action" value="delete_contest">
            <div class="flex gap-3 justify-end">
                <button type="button"
                        onclick="document.getElementById('delete-dialog').close(); document.getElementById('delete-confirm-input').value = ''; document.getElementById('delete-confirm-btn').disabled = true;"
                        class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-4 rounded-lg text-sm transition">
                    Cancel
                </button>
                <button type="submit" id="delete-confirm-btn" disabled
                        class="bg-red-600 hover:bg-red-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold py-2 px-4 rounded-lg text-sm transition">
                    Delete Contest
                </button>
            </div>
        </form>
    </dialog>

    {# ── SETTINGS FORM ── #}
    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm mb-8">
        <h2 class="text-base text-gray-800 mb-4">Contest Settings</h2>

        <form id="settings-form" method="POST" action="/admin/contests/{{ contest.id }}">
            <input type="hidden" name="_action" value="save_settings">

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">

                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
                    <input type="text" id="name" name="name"
                           value="{{ contest.name }}" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="year" class="block text-sm font-medium text-gray-700 mb-1">Year</label>
                    <input type="number" id="year" name="year"
                           value="{{ contest.year }}" min="2000" max="2100" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="budget_limit" class="block text-sm font-medium text-gray-700 mb-1">Budget (€m)</label>
                    <input type="number" id="budget_limit" name="budget_limit"
                           value="{{ contest.budget_limit }}" step="0.1" min="0.1" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="launch_date" class="block text-sm font-medium text-gray-700 mb-1">Launch Date <span class="text-gray-400 font-normal">(optional)</span></label>
                    <input type="date" id="launch_date" name="launch_date"
                           value="{{ contest.launch_date ?? '' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select id="status" name="status"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 bg-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        {% for s in valid_statuses %}
                            <option value="{{ s }}" {{ contest.status == s ? 'selected' : '' }}>{{ s|capitalize }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="flex items-end pb-1">
                    <label class="flex items-center gap-3 cursor-pointer">
                        <div class="relative">
                            <input type="checkbox" name="is_active" value="1"
                                   {{ contest.is_active ? 'checked' : '' }}
                                   class="sr-only peer">
                            <div class="w-10 h-6 bg-gray-200 rounded-full peer peer-checked:bg-indigo-600 transition"></div>
                            <div class="absolute top-0.5 left-0.5 w-5 h-5 bg-white rounded-full shadow transition peer-checked:translate-x-4"></div>
                        </div>
                        <span class="text-sm font-medium text-gray-700">Set as current contest</span>
                    </label>
                </div>

            </div>

        </form>
    </div>

    {# ── SCORE SAVE FORM (wraps all score inputs via the form= attribute) ── #}
    {% if contest.status in ['open', 'closed'] %}
        <form id="scores-form" method="POST" action="/admin/contests/{{ contest.id }}">
            <input type="hidden" name="_action" value="save_scores">
        </form>
    {% endif %}

    {# ── GROUPS & COUNTRIES ── #}
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-base text-gray-800">Groups &amp; Countries</h2>
        {% if contest.status in ['open', 'closed'] %}
            <button type="submit" form="scores-form"
                    class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-1.5 px-4 rounded-lg transition text-sm">
                Save Scores
            </button>
        {% endif %}
    </div>

    {% if groups %}
        <div class="space-y-6 mb-8">
            {% for group in groups %}
                <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">

                    {# Group header #}
                    <div class="flex items-center justify-between px-5 py-3 border-b border-gray-100"
                         style="border-left: 4px solid {{ group.colour }}">
                        <div class="flex items-center gap-3">
                            <span class="font-semibold text-gray-800 text-sm">{{ group.name }}</span>
                            {% if group.is_wildcard %}
                                <span class="text-xs bg-amber-100 text-amber-700 font-semibold px-2 py-0.5 rounded-full">Wildcard</span>
                            {% endif %}
                        </div>
                        <div class="flex gap-3 items-center">
                            {# Edit group toggle #}
                            <button type="button"
                                    onclick="this.closest('.group-card').querySelector('.group-edit-form').classList.toggle('hidden')"
                                    class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">Edit</button>
                            {# Delete group #}
                            <form method="POST" action="/admin/contests/{{ contest.id }}" class="inline"
                                  onsubmit="return confirm('Delete group {{ group.name }}?')">
                                <input type="hidden" name="_action" value="delete_group">
                                <input type="hidden" name="group_id" value="{{ group.id }}">
                                <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">Delete</button>
                            </form>
                        </div>
                    </div>

                    <div class="group-card">

                        {# Inline edit form (hidden by default) #}
                        <div class="group-edit-form hidden px-5 py-4 bg-gray-50 border-b border-gray-100">
                            <form method="POST" action="/admin/contests/{{ contest.id }}"
                                  class="flex flex-wrap gap-3 items-end">
                                <input type="hidden" name="_action" value="edit_group">
                                <input type="hidden" name="group_id" value="{{ group.id }}">
                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Name</label>
                                    <input type="text" name="group_name" value="{{ group.name }}" required
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Colour</label>
                                    <input type="color" name="group_colour" value="{{ group.colour }}"
                                           class="h-9 w-12 rounded border border-gray-300 cursor-pointer">
                                </div>
                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Sort Order</label>
                                    <input type="number" name="sort_order" value="{{ group.sort_order }}"
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm w-20 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>
                                <label class="flex items-center gap-2 cursor-pointer pb-1">
                                    <input type="checkbox" name="is_wildcard" value="1"
                                           {{ group.is_wildcard ? 'checked' : '' }}
                                           class="w-4 h-4 text-indigo-600 rounded border-gray-300">
                                    <span class="text-sm text-gray-700">Wildcard</span>
                                </label>
                                <button type="submit"
                                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-1.5 px-4 rounded-lg transition text-sm">
                                    Update
                                </button>
                            </form>
                        </div>

                        {# Countries table #}
                        {% set groupCountries = countries_by_group[group.id] ?? [] %}
                        {% if groupCountries %}
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide border-b border-gray-100">
                                        <th class="px-4 py-2 text-left">Country</th>
                                        <th class="px-4 py-2 text-right">Price (€m)</th>
                                        <th class="px-4 py-2 text-center">Order</th>
                                        <th class="px-4 py-2 text-right">Score</th>
                                        <th class="px-4 py-2 text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    {% for country in groupCountries %}
                                        <tr class="hover:bg-gray-50 transition">
                                            <td class="px-4 py-2 font-medium text-gray-800">
                                                {{ country.flag_emoji }} {{ country.name }}
                                            </td>
                                            <td class="px-4 py-2 text-right">
                                                <form method="POST" action="/admin/contests/{{ contest.id }}"
                                                      class="inline-flex items-center gap-1 justify-end">
                                                    <input type="hidden" name="_action" value="edit_country">
                                                    <input type="hidden" name="country_id" value="{{ country.id }}">
                                                    <input type="number" name="country_price"
                                                           value="{{ country.price }}"
                                                           step="0.1" min="0.1"
                                                           class="w-16 border border-gray-200 rounded px-1.5 py-0.5 text-sm text-right text-gray-900 focus:outline-none focus:ring-1 focus:ring-indigo-400">
                                                    <input type="hidden" name="running_order" value="{{ country.running_order ?? '' }}">
                                                    <button type="submit" class="text-xs text-indigo-600 hover:text-indigo-800 font-medium">✓</button>
                                                </form>
                                            </td>
                                            <td class="px-4 py-2 text-center text-gray-500 text-xs">
                                                {{ country.running_order ?? '—' }}
                                            </td>
                                            <td class="px-4 py-2 text-right">
                                                {% if contest.status in ['open', 'closed'] %}
                                                    <input type="number" name="scores[{{ country.id }}]"
                                                           value="{{ country.final_score_raw ?? '' }}"
                                                           form="scores-form"
                                                           placeholder="—"
                                                           class="w-16 border border-gray-200 rounded px-1.5 py-0.5 text-sm text-right text-gray-900 focus:outline-none focus:ring-1 focus:ring-emerald-400">
                                                {% else %}
                                                    <span class="text-gray-500">{{ country.final_score_raw ?? '—' }}</span>
                                                {% endif %}
                                            </td>
                                            <td class="px-4 py-2 text-right">
                                                <form method="POST" action="/admin/contests/{{ contest.id }}" class="inline"
                                                      onsubmit="return confirm('Remove {{ country.name }} from this contest?')">
                                                    <input type="hidden" name="_action" value="delete_country">
                                                    <input type="hidden" name="country_id" value="{{ country.id }}">
                                                    <button type="submit" class="text-xs text-red-500 hover:text-red-700 font-medium">Remove</button>
                                                </form>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        {% else %}
                            <p class="px-5 py-3 text-sm text-gray-400">No countries in this group yet.</p>
                        {% endif %}

                        {# Add country to this group #}
                        <div class="px-5 py-4 bg-gray-50 border-t border-gray-100">
                            <form method="POST" action="/admin/contests/{{ contest.id }}"
                                  class="flex flex-wrap gap-3 items-end">
                                <input type="hidden" name="_action" value="add_country">
                                <input type="hidden" name="country_group_id" value="{{ group.id }}">

                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Country</label>
                                    <select name="country_catalogue_id"
                                            onchange="
                                                var opt = this.options[this.selectedIndex];
                                                var nameField = this.closest('form').querySelector('[name=country_name]');
                                                var emojiField = this.closest('form').querySelector('[name=flag_emoji]');
                                                if (opt.value) {
                                                    nameField.value = opt.dataset.name || '';
                                                    emojiField.value = opt.dataset.emoji || '';
                                                }
                                            "
                                            class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                        <option value="">— Pick from catalogue —</option>
                                        {% for cat in all_country_catalogue %}
                                            <option value="{{ cat.id }}"
                                                    data-name="{{ cat.name }}"
                                                    data-emoji="{{ cat.flag_emoji ?? '' }}">
                                                {{ cat.flag_emoji }} {{ cat.name }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Name <span class="text-gray-400">(if custom)</span></label>
                                    <input type="text" name="country_name" placeholder="Override name"
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>

                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Flag</label>
                                    <input type="text" name="flag_emoji" maxlength="8" placeholder="🇬🇧"
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm w-16 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>

                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Price (€m)</label>
                                    <input type="number" name="country_price" step="0.1" min="0.1" required
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm w-20 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>

                                <div>
                                    <label class="block text-xs font-medium text-gray-600 mb-1">Running Order</label>
                                    <input type="number" name="running_order" min="1"
                                           class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm w-20 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                </div>

                                <button type="submit"
                                        class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-1.5 px-4 rounded-lg transition text-sm">
                                    Add
                                </button>
                            </form>
                        </div>

                    </div>{# end .group-card #}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-gray-400 text-sm mb-6">No groups yet. Add one below.</p>
    {% endif %}

    {# ── ADD GROUP ── #}
    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm">
        <h2 class="text-base text-gray-700 mb-4">Add Group to Contest</h2>
        <form method="POST" action="/admin/contests/{{ contest.id }}"
              class="flex flex-wrap gap-3 items-end">
            <input type="hidden" name="_action" value="add_group">

            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">From Catalogue</label>
                <select name="group_catalogue_id"
                        onchange="
                            var opt = this.options[this.selectedIndex];
                            var nameField = this.closest('form').querySelector('[name=group_name]');
                            var colourField = this.closest('form').querySelector('[name=group_colour]');
                            if (opt.value) {
                                nameField.value = opt.dataset.name || '';
                                colourField.value = opt.dataset.colour || '#6366f1';
                            }
                        "
                        class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <option value="">— Pick from catalogue —</option>
                    {% for g in all_group_catalogue %}
                        <option value="{{ g.id }}" data-name="{{ g.name }}" data-colour="{{ g.colour }}">
                            {{ g.name }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Name <span class="text-gray-400">(or custom)</span></label>
                <input type="text" name="group_name" placeholder="e.g. Semi-Final 1"
                       class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>

            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Colour</label>
                <input type="color" name="group_colour" value="#6366f1"
                       class="h-9 w-12 rounded border border-gray-300 cursor-pointer">
            </div>

            <div>
                <label class="block text-xs font-medium text-gray-600 mb-1">Sort Order</label>
                <input type="number" name="sort_order" value="{{ groups|length }}"
                       class="border border-gray-300 rounded-lg px-2 py-1.5 text-sm w-20 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500">
            </div>

            <label class="flex items-center gap-2 cursor-pointer pb-1">
                <input type="checkbox" name="is_wildcard" value="1"
                       class="w-4 h-4 text-indigo-600 rounded border-gray-300">
                <span class="text-sm text-gray-700">Wildcard group</span>
            </label>

            <button type="submit"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-1.5 px-5 rounded-lg transition text-sm">
                Add Group
            </button>
        </form>
    </div>

{% endblock %}
