<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block page_title %}Admin{% endblock %} — {{ site_name }} CMS</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body class="h-full">
<div class="min-h-full">

    {# ── SIDEBAR ── #}
    <div class="fixed inset-y-0 left-0 flex w-56 flex-col">
        <div class="flex grow flex-col overflow-y-auto bg-slate-900 px-4 pb-4">

            {# Logo #}
            <div class="flex h-16 shrink-0 items-center border-b border-slate-700 mb-2">
                <div>
                    <p class="text-white font-bold text-sm leading-tight">🎤 {{ site_name }}</p>
                    <p class="text-slate-400 text-xs">Content Management</p>
                </div>
            </div>

            {# Nav #}
            <nav class="flex flex-1 flex-col mt-2">
                <ul class="flex flex-1 flex-col gap-y-1">

                    <li>
                        <a href="/admin"
                           class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition
                                  {{ current_path == '/admin' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }}">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                            </svg>
                            Dashboard
                        </a>
                    </li>

                    <li class="pt-3">
                        <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Contest</p>
                    </li>

                    <li>
                        <a href="/admin/contest"
                           class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition
                                  {{ current_path == '/admin/contest' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }}">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            Settings
                        </a>
                    </li>

                    <li>
                        <a href="/admin/groups"
                           class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition
                                  {{ current_path == '/admin/groups' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }}">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                            </svg>
                            Groups
                        </a>
                    </li>

                    <li>
                        <a href="/admin/countries"
                           class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition
                                  {{ current_path == '/admin/countries' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }}">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
                            </svg>
                            Countries
                        </a>
                    </li>

                    <li>
                        <a href="/admin/scores"
                           class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium transition
                                  {{ current_path == '/admin/scores' ? 'bg-slate-700 text-white' : 'text-slate-300 hover:bg-slate-800 hover:text-white' }}">
                            <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                            </svg>
                            Scores
                        </a>
                    </li>

                </ul>

                {# Bottom: view site + sign out #}
                <div class="border-t border-slate-700 pt-3 mt-3 space-y-1">
                    <a href="/" target="_blank"
                       class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition">
                        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        View Site
                    </a>
                    <a href="/admin/logout"
                       class="flex items-center gap-x-3 rounded-lg px-3 py-2 text-sm font-medium text-slate-400 hover:bg-slate-800 hover:text-white transition">
                        <svg class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Sign Out
                    </a>
                </div>
            </nav>

        </div>
    </div>

    {# ── MAIN AREA ── #}
    <div class="pl-56 min-h-screen flex flex-col">

        {# Top bar #}
        <div class="sticky top-0 z-10 flex h-14 shrink-0 items-center justify-between border-b border-gray-200 bg-white px-6 shadow-sm">
            <h1 class="text-sm font-semibold text-gray-700">{{ block('page_title') }}</h1>
            <span class="text-xs text-gray-400">Logged in as {{ user_name }}</span>
        </div>

        {# Flash message #}
        {% if flash %}
            <div class="px-6 py-3 text-sm font-medium border-b
                {% if flash.type == 'success' %}bg-green-50 border-green-200 text-green-800
                {% else %}bg-red-50 border-red-200 text-red-800{% endif %}">
                {{ flash.message }}
            </div>
        {% endif %}

        <main class="flex-1 p-6">
            {% block content %}{% endblock %}
        </main>

    </div>

</div>
</body>
</html>
