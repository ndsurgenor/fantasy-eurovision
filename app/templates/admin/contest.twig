{% extends 'admin/base.twig' %}

{% block page_title %}Contest Settings{% endblock %}

{% block content %}
    {% if errors is defined and errors %}
        <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-6">
            {% for error in errors %}
                <p class="text-red-700 text-sm">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="POST" action="/admin/contest"
          class="bg-white border border-gray-200 rounded-xl p-6 max-w-lg shadow-sm space-y-5">

        <div>
            <label for="year" class="block text-sm font-medium text-gray-700 mb-1">Year</label>
            <input type="number" id="year" name="year"
                   value="{{ contest.year ?? '' }}"
                   min="2000" max="2100" required
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Contest Name</label>
            <input type="text" id="name" name="name"
                   value="{{ contest.name ?? '' }}"
                   required
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div>
            <label for="budget_limit" class="block text-sm font-medium text-gray-700 mb-1">Budget Limit (€m)</label>
            <input type="number" id="budget_limit" name="budget_limit"
                   value="{{ contest.budget_limit ?? '' }}"
                   step="0.1" min="0.1" required
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
        </div>

        <div>
            <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Status</label>
            <select id="status" name="status" required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                {% for s in valid_statuses %}
                    <option value="{{ s }}" {% if contest.status is defined and contest.status == s %}selected{% endif %}>
                        {{ s|capitalize }}
                    </option>
                {% endfor %}
            </select>
            <p class="text-gray-400 text-xs mt-1">Flow: setup → open → locked → scored</p>
        </div>

        <button type="submit"
                class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition">
            {{ contest is defined and contest ? 'Update Contest' : 'Create Contest' }}
        </button>
    </form>
{% endblock %}
