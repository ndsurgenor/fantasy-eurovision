{% extends 'admin/base.twig' %}

{% block page_title %}Groups Catalogue{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        {# Form #}
        <div>
            <h2 class="text-base text-gray-700 mb-3">
                {{ edit_entry ? 'Edit Group' : 'Add Group' }}
            </h2>

            <form method="POST" action="/admin/groups"
                  class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm space-y-4">

                <input type="hidden" name="action" value="{{ edit_entry ? 'edit' : 'create' }}">
                {% if edit_entry %}
                    <input type="hidden" name="entry_id" value="{{ edit_entry.id }}">
                {% endif %}

                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Group Name</label>
                    <input type="text" id="name" name="name"
                           value="{{ edit_entry.name ?? '' }}"
                           required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label for="colour" class="block text-sm font-medium text-gray-700 mb-1">Colour</label>
                    <div class="flex items-center gap-3">
                        <input type="color" id="colour" name="colour"
                               value="{{ edit_entry.colour ?? '#6366f1' }}"
                               class="h-9 w-16 rounded border border-gray-300 cursor-pointer">
                        <span class="text-xs text-gray-500">Used to identify this group visually in contests.</span>
                    </div>
                </div>

                <div class="flex gap-3 pt-1">
                    <button type="submit"
                            class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-5 rounded-lg transition text-sm">
                        {{ edit_entry ? 'Update Group' : 'Add to Catalogue' }}
                    </button>
                    {% if edit_entry %}
                        <a href="/admin/groups"
                           class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2 px-5 rounded-lg transition text-sm flex items-center">
                            Cancel
                        </a>
                    {% endif %}
                </div>
            </form>
        </div>

        {# Catalogue list #}
        <div>
            <h2 class="text-base text-gray-700 mb-3">Group Catalogue</h2>

            {% if groups %}
                <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
                    <ul class="divide-y divide-gray-100">
                        {% for g in groups %}
                            <li class="flex items-center justify-between px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <span class="inline-block w-3 h-3 rounded-full shrink-0"
                                          style="background-color: {{ g.colour }}"></span>
                                    <span class="font-medium text-gray-800 text-sm">{{ g.name }}</span>
                                </div>
                                <div class="flex gap-2">
                                    <a href="/admin/groups?edit={{ g.id }}"
                                       class="text-xs bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium py-1 px-3 rounded-lg transition">Edit</a>
                                    <form method="POST" action="/admin/groups" class="inline"
                                          onsubmit="return confirm('Remove {{ g.name }} from the catalogue?')">
                                        <input type="hidden" name="action" value="delete">
                                        <input type="hidden" name="entry_id" value="{{ g.id }}">
                                        <button type="submit"
                                                class="text-xs bg-red-50 hover:bg-red-100 text-red-600 font-medium py-1 px-3 rounded-lg transition">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            {% else %}
                <p class="text-gray-400 text-sm">No groups in the catalogue yet.</p>
            {% endif %}
        </div>

    </div>
{% endblock %}
