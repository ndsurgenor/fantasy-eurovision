{% extends 'base.twig' %}

{% block title %}Pick Your Team | {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="text-3xl text-white mb-2 tracking-tight">Pick Your Team</h1>
    <p class="text-white/85 mb-1">Choose exactly 8 countries with a total value of no more than €{{ contest.budget_limit|number_format(1) }}m from the groups below.</p>
    <p class="text-white/85 mb-6">You must pick at least 1 and no more than 2 from each group.</p>

    {% if errors is defined and errors %}
        <div class="bg-rose-500/20 border border-rose-500/40 rounded-lg px-4 py-3 mb-6">
            {% for error in errors %}
                <p class="text-rose-300 text-sm">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="POST" action="/select" id="team-form"
          data-budget="{{ contest.budget_limit }}"
          data-required-picks="8">

        {# Budget / picks tracker #}
        <div class="bg-stage-900 border border-white/10 rounded-xl p-4 mb-6 flex flex-wrap gap-x-6 gap-y-2 items-center text-sm sticky top-4 z-10">
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Countries:</span>
                <span id="countries-count" class="font-bold text-white tabular-nums inline-block w-8 text-right">0/8</span>
            </div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Groups:</span>
                <span id="groups-count" class="font-bold text-white tabular-nums inline-block w-8 text-right">0/0</span>
            </div>
            <div class="w-full sm:hidden"></div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Spent:</span>
                <span id="budget-spent" class="font-bold text-white tabular-nums inline-block w-14 text-right">€0.0m</span>
            </div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Remaining:</span>
                <span id="budget-remaining" class="font-bold text-emerald-400 tabular-nums inline-block w-16 text-right">€{{ contest.budget_limit|number_format(1) }}m</span>
            </div>
            <div class="ml-auto flex items-center">
                <div class="grid grid-cols-3 border border-white/20 rounded-lg overflow-hidden text-xs">
                    <button type="button" id="view-groups" title="Group view"
                            class="flex justify-center items-center gap-1.5 px-2.5 py-1.5 bg-white/20 text-white transition">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                            <path fill-rule="evenodd" d="M4.25 2A2.25 2.25 0 0 0 2 4.25v2.5A2.25 2.25 0 0 0 4.25 9h2.5A2.25 2.25 0 0 0 9 6.75v-2.5A2.25 2.25 0 0 0 6.75 2h-2.5zm0 9A2.25 2.25 0 0 0 2 13.25v2.5A2.25 2.25 0 0 0 4.25 18h2.5A2.25 2.25 0 0 0 9 15.75v-2.5A2.25 2.25 0 0 0 6.75 11h-2.5zm9-9A2.25 2.25 0 0 0 11 4.25v2.5A2.25 2.25 0 0 0 13.25 9h2.5A2.25 2.25 0 0 0 18 6.75v-2.5A2.25 2.25 0 0 0 15.75 2h-2.5zm0 9A2.25 2.25 0 0 0 11 13.25v2.5A2.25 2.25 0 0 0 13.25 18h2.5A2.25 2.25 0 0 0 18 15.75v-2.5A2.25 2.25 0 0 0 15.75 11h-2.5z" clip-rule="evenodd" />
                        </svg>
                        Groups
                    </button>
                    <button type="button" id="view-order" title="Running order view"
                            class="flex justify-center items-center gap-1.5 px-2.5 py-1.5 text-white/50 hover:text-white/85 hover:bg-white/10 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                            <path fill-rule="evenodd" d="M6 4.75A.75.75 0 0 1 6.75 4h10.5a.75.75 0 0 1 0 1.5H6.75A.75.75 0 0 1 6 4.75ZM6 10a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H6.75A.75.75 0 0 1 6 10Zm0 5.25a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H6.75a.75.75 0 0 1-.75-.75ZM1.99 4.75a1 1 0 0 1 1-1H3a1 1 0 0 1 1 1v.01a1 1 0 0 1-1 1h-.01a1 1 0 0 1-1-1v-.01ZM1.99 15.25a1 1 0 0 1 1-1H3a1 1 0 0 1 1 1v.01a1 1 0 0 1-1 1h-.01a1 1 0 0 1-1-1v-.01ZM1.99 10a1 1 0 0 1 1-1H3a1 1 0 0 1 1 1v.01a1 1 0 0 1-1 1h-.01a1 1 0 0 1-1-1V10Z" clip-rule="evenodd" />
                        </svg>
                        Order
                    </button>
                    <button type="button" id="view-price" title="Price order view"
                            class="flex justify-center items-center gap-1.5 px-2.5 py-1.5 text-white/50 hover:text-white/85 hover:bg-white/10 transition">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                            <path fill-rule="evenodd" d="M10 1C13.866 1 17 2.79086 17 5C17 7.20914 13.866 9 10 9C6.13401 9 3 7.20914 3 5C3 2.79086 6.13401 1 10 1ZM15.694 9.13079C16.1576 8.86588 16.6044 8.54736 17 8.17775V10C17 12.2091 13.866 14 10 14C6.13401 14 3 12.2091 3 10V8.17775C3.3956 8.54736 3.84244 8.86588 4.30604 9.13079C5.83803 10.0062 7.85433 10.5 10 10.5C12.1457 10.5 14.162 10.0062 15.694 9.13079ZM3 13.1777V15C3 17.2091 6.13401 19 10 19C13.866 19 17 17.2091 17 15V13.1777C16.6044 13.5474 16.1576 13.8659 15.694 14.1308C14.162 15.0062 12.1457 15.5 10 15.5C7.85433 15.5 5.83803 15.0062 4.30604 14.1308C3.84244 13.8659 3.3956 13.5474 3 13.1777Z" clip-rule="evenodd" />
                        </svg>
                        Prices
                    </button>
                </div>
            </div>
        </div>

        {# Groups & countries #}
        {% for group in groups %}
            <div class="mb-6" data-group-container data-group-id="{{ group.id }}" data-is-wildcard="{{ group.is_wildcard ? '1' : '0' }}">
                <div class="flex items-center gap-3 mb-3">
                    <h2 class="text-lg text-fuchsia-400">{{ group.name }}</h2>
                    {% if group.is_wildcard %}
                        <span class="text-xs bg-emerald-400/20 text-emerald-400 font-bold px-2 py-0.5 rounded-full">Wildcard (optional)</span>
                    {% else %}
                        <span class="text-xs text-white/85">
                            Picks: <span data-group-display="{{ group.id }}" class="font-semibold text-white">0/2</span>
                        </span>
                    {% endif %}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
                    {% for country in countries_by_group[group.id] ?? [] %}
                        <label data-running-order="{{ country.running_order ?? 0 }}"
                               class="flex items-center gap-3 bg-stage-900 border border-white/10 rounded-lg p-3 cursor-pointer hover:border-fuchsia-500/60 transition has-[:checked]:border-fuchsia-500 has-[:checked]:bg-fuchsia-500/10">
                            <span class="ro-number hidden text-fuchsia-400 text-xs font-bold tabular-nums w-5 text-center flex-shrink-0"></span>
                            <input type="checkbox"
                                   name="countries[]"
                                   value="{{ country.id }}"
                                   data-price="{{ country.price }}"
                                   data-group-id="{{ country.group_id }}"
                                   {% if country.id in checked_ids %}checked{% endif %}
                                   class="country-checkbox accent-fuchsia-500 w-4 h-4 flex-shrink-0 mr-1">
                            {% if country.flag_image %}
                                <img src="/uploads/flags/{{ country.flag_image }}" alt="{{ country.name }}" class="h-auto w-auto flex-shrink-0 rounded-sm">
                            {% endif %}
                            <div class="flex-1 min-w-0 flex items-center justify-between gap-2">
                                <div class="flex items-center gap-1 min-w-0">
                                    <p class="price-name font-medium text-white text-sm truncate min-w-0">{{ country.name }}</p>
                                    <span class="price-rank-icon hidden flex-shrink-0" data-group="{{ group.name }}">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3">
                                            <path fill-rule="evenodd" d="M10 1C13.866 1 17 2.79086 17 5C17 7.20914 13.866 9 10 9C6.13401 9 3 7.20914 3 5C3 2.79086 6.13401 1 10 1ZM15.694 9.13079C16.1576 8.86588 16.6044 8.54736 17 8.17775V10C17 12.2091 13.866 14 10 14C6.13401 14 3 12.2091 3 10V8.17775C3.3956 8.54736 3.84244 8.86588 4.30604 9.13079C5.83803 10.0062 7.85433 10.5 10 10.5C12.1457 10.5 14.162 10.0062 15.694 9.13079ZM3 13.1777V15C3 17.2091 6.13401 19 10 19C13.866 19 17 17.2091 17 15V13.1777C16.6044 13.5474 16.1576 13.8659 15.694 14.1308C14.162 15.0062 12.1457 15.5 10 15.5C7.85433 15.5 5.83803 15.0062 4.30604 14.1308C3.84244 13.8659 3.3956 13.5474 3 13.1777Z" clip-rule="evenodd" />
                                        </svg>
                                    </span>
                                </div>
                                <p class="text-white/85 text-xs whitespace-nowrap flex-shrink-0">€{{ country.price|number_format(1) }}m</p>
                            </div>
                        </label>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}

        {# Running order view container — populated by JS #}
        <div id="order-container" class="hidden mb-6"></div>

        {# Price order view container — populated by JS #}
        <div id="price-container" class="hidden mb-6"></div>

        <div class="mt-6 text-center">
            <button type="submit" id="submit-btn" disabled
                    class="bg-gradient-to-r from-fuchsia-500 to-purple-600 hover:from-fuchsia-400 hover:to-purple-500 disabled:opacity-40 disabled:cursor-not-allowed text-white font-bold py-3 px-8 rounded-lg transition text-base">
                Submit My Team
            </button>
        </div>
    </form>

    <script src="/js/select.js"></script>
{% endblock %}
