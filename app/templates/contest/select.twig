{% extends 'base.twig' %}

{% block title %}Pick Your Team | {{ site_name }}{% endblock %}

{% block content %}
    <h1 class="text-3xl text-white mb-2 tracking-tight">Pick Your Team</h1>
    <p class="text-white/85 mb-1">Choose exactly 8 countries with a total value of no more than €{{ contest.budget_limit|number_format(1) }}m from the groups below.</p>
    <p class="text-white/85 mb-6">You must pick at least 1 and no more than 2 from each group.</p>

    {% if errors is defined and errors %}
        <div class="bg-rose-500/20 border border-rose-500/40 rounded-lg px-4 py-3 mb-6">
            {% for error in errors %}
                <p class="text-rose-300 text-sm">{{ error }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <form method="POST" action="/select" id="team-form"
          data-budget="{{ contest.budget_limit }}"
          data-required-picks="8">

        {# Budget / picks tracker #}
        <div class="bg-stage-900 border border-white/10 rounded-xl p-4 mb-6 flex flex-wrap gap-x-6 gap-y-2 text-sm sticky top-4 z-10">
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Countries:</span>
                <span id="countries-count" class="font-bold text-white tabular-nums inline-block w-8 text-right">0/8</span>
            </div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Groups:</span>
                <span id="groups-count" class="font-bold text-white tabular-nums inline-block w-8 text-right">0/0</span>
            </div>
            <div class="w-full sm:hidden"></div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Spent:</span>
                <span id="budget-spent" class="font-bold text-white tabular-nums inline-block w-14 text-right">€0.0m</span>
            </div>
            <div class="flex items-baseline gap-1">
                <span class="text-white/85">Remaining:</span>
                <span id="budget-remaining" class="font-bold text-emerald-400 tabular-nums inline-block w-16 text-right">€{{ contest.budget_limit|number_format(1) }}m</span>
            </div>
        </div>

        {# Groups & countries #}
        {% for group in groups %}
            <div class="mb-6" data-group-container data-group-id="{{ group.id }}" data-is-wildcard="{{ group.is_wildcard ? '1' : '0' }}">
                <div class="flex items-center gap-3 mb-3">
                    <h2 class="text-lg text-fuchsia-400">{{ group.name }}</h2>
                    {% if group.is_wildcard %}
                        <span class="text-xs bg-emerald-400/20 text-emerald-400 font-bold px-2 py-0.5 rounded-full">Wildcard (optional)</span>
                    {% else %}
                        <span class="text-xs text-white/85">
                            Picks: <span data-group-display="{{ group.id }}" class="font-semibold text-white">0/2</span>
                        </span>
                    {% endif %}
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
                    {% for country in countries_by_group[group.id] ?? [] %}
                        <label class="flex items-center gap-3 bg-stage-900 border border-white/10 rounded-lg p-3 cursor-pointer hover:border-fuchsia-500/60 transition has-[:checked]:border-fuchsia-500 has-[:checked]:bg-fuchsia-500/10">
                            <input type="checkbox"
                                   name="countries[]"
                                   value="{{ country.id }}"
                                   data-price="{{ country.price }}"
                                   data-group-id="{{ country.group_id }}"
                                   {% if country.id in checked_ids %}checked{% endif %}
                                   class="country-checkbox accent-fuchsia-500 w-4 h-4 flex-shrink-0">
                            {% if country.flag_image %}
                                <img src="/uploads/flags/{{ country.flag_image }}" alt="{{ country.name }}" class="h-auto w-auto flex-shrink-0 rounded-sm">
                            {% endif %}
                            <div class="flex-1 min-w-0 flex items-center justify-between gap-2">
                                <p class="font-medium text-white text-sm truncate">{{ country.name }}</p>
                                <p class="text-white/85 text-xs whitespace-nowrap">€{{ country.price|number_format(1) }}m</p>
                            </div>
                        </label>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}

        <div class="mt-6">
            <button type="submit" id="submit-btn" disabled
                    class="bg-gradient-to-r from-fuchsia-500 to-purple-600 hover:from-fuchsia-400 hover:to-purple-500 disabled:opacity-40 disabled:cursor-not-allowed text-white font-bold py-3 px-8 rounded-lg transition text-base">
                Submit My Team
            </button>
        </div>
    </form>

    <script src="/js/select.js"></script>
{% endblock %}
