{% extends 'base.twig' %}

{% block title %}My Team | {{ site_name }}{% endblock %}

{% block content %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl text-white tracking-tight">My Team</h1>
        {% if is_finished %}
            <span class="bg-emerald-400/20 text-emerald-400 text-sm font-semibold px-3 py-1 rounded-full">Finished</span>
        {% elseif is_closed %}
            <span class="bg-fuchsia-500/20 text-fuchsia-400 text-sm font-semibold px-3 py-1 rounded-full">Closed</span>
        {% else %}
            <span class="bg-white/10 text-white/60 text-sm font-semibold px-3 py-1 rounded-full">Open</span>
        {% endif %}
    </div>

    <div class="bg-stage-900 border border-white/10 rounded-xl overflow-hidden mb-6">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-white/5 text-white/40 text-xs uppercase tracking-wider">
                    <th class="px-4 py-3 text-left">Country</th>
                    <th class="px-4 py-3 text-left hidden sm:table-cell">Group</th>
                    <th class="px-4 py-3 text-right hidden sm:table-cell">Price</th>
                    {% if is_finished %}
                        <th class="px-4 py-3 text-right">Points</th>
                        <th class="px-4 py-3 text-right">Score</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                {% for pick in picks %}
                    <tr class="hover:bg-white/5 transition">
                        <td class="px-4 py-3 font-medium text-white">
                            {% if pick.flag_image %}
                                <img src="/uploads/flags/{{ pick.flag_image }}" alt="{{ pick.name }}" class="h-6 w-auto mr-2 rounded-sm flex-shrink-0 inline-block align-middle">
                            {% endif %}
                            {{ pick.name }}
                        </td>
                        <td class="px-4 py-3 text-white/75 hidden sm:table-cell">{{ pick.group_name }}</td>
                        <td class="px-4 py-3 text-right text-white/75 hidden sm:table-cell">€{{ pick.price|number_format(1) }}m</td>
                        {% if is_finished %}
                            <td class="px-4 py-3 text-right text-white/75">
                                {% if pick.final_score_raw is not null %}
                                    {{ pick.final_score_raw }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right font-bold
                                {% if pick.score > 0 %}text-emerald-400
                                {% elseif pick.score < 0 %}text-rose-400
                                {% else %}text-white/30{% endif %}">
                                {{ pick.score > 0 ? '+' : '' }}{{ pick.score }}
                            </td>
                        {% endif %}
                    </tr>
                {% endfor %}
            </tbody>
            {% if is_finished %}
                <tfoot>
                    <tr class="bg-white/5 font-bold">
                        <td class="px-4 py-3 text-white/60" colspan="{% if is_finished %}3{% else %}2{% endif %}">Total</td>
                        <td class="px-4 py-3 text-right"></td>
                        <td class="px-4 py-3 text-right text-emerald-400 text-base">{{ total_score }}</td>
                    </tr>
                </tfoot>
            {% endif %}
        </table>
    </div>

    <div class="flex flex-wrap gap-4 text-sm text-white/75">
        <span>Budget spent: <strong class="text-white">€{{ entry.total_cost|number_format(1) }}m</strong></span>
        {% if is_finished %}
            <span>Total score: <strong class="text-emerald-400">{{ total_score }}</strong></span>
            <a href="/leaderboard" class="text-fuchsia-400 hover:text-fuchsia-300 hover:underline font-semibold">View Leaderboard →</a>
        {% endif %}
    </div>
{% endblock %}
