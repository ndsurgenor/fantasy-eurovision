{% extends 'base.twig' %}

{% block title %}My Team | {{ site_name }}{% endblock %}

{% block content %}
    <div class="flex flex-wrap items-center justify-between gap-4 mt-4 mb-6">
        <h1 class="text-3xl">My Team</h1>
        {% if is_open %}
            <div class="flex flex-wrap items-center gap-3">
                {% if launch_date and launch_time %}
                    <p class="text-sm text-white/85">Updates can be made up until <strong class="text-white">{{ launch_time|date('g:ia') }}</strong> on <strong class="text-white">{{ launch_date|date('l jS F Y') }}</strong></p>
                {% endif %}
                <a href="/select" class="bg-gradient-to-r from-fuchsia-600 to-purple-700 hover:from-fuchsia-500 hover:to-purple-600 text-white font-bold py-2 px-6 rounded-lg transition text-sm">Update Team</a>
            </div>
        {% elseif is_finished %}
            <span class="bg-emerald-400/20 text-emerald-400 text-sm font-semibold px-3 py-1 rounded-full">Finished</span>
        {% else %}
            <p class="text-sm text-white/85">Team selection is now closed.</p>
        {% endif %}
    </div>

    <div class="bg-stage-900 border border-white/10 rounded-xl overflow-hidden mb-6">
        <table id="my-team-table" class="w-full text-sm">
            <thead>
                <tr class="bg-white/5 text-white/85 text-xs uppercase tracking-wider">
                    <th class="px-4 py-3 text-left cursor-pointer select-none" data-col="0" data-sort-type="number"><span class="sm:hidden">#</span><span class="hidden sm:inline">Order</span> <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                    <th class="px-4 py-3 text-left cursor-pointer select-none" data-col="1" data-sort-type="text">Country <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                    <th class="px-4 py-3 text-left hidden sm:table-cell cursor-pointer select-none" data-col="2" data-sort-type="text">Group <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                    <th class="px-4 py-3 text-right cursor-pointer select-none" data-col="3" data-sort-type="number">Price <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                    {% if is_finished %}
                        <th class="px-4 py-3 text-right cursor-pointer select-none" data-col="4" data-sort-type="number">Points <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                        <th class="px-4 py-3 text-right cursor-pointer select-none" data-col="5" data-sort-type="number">Score <span class="sort-icon relative inline-block w-4 h-4" style="vertical-align:-0.35em"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute inset-0 m-auto w-3 h-3"><polyline points="3,6 8,2 13,6"/><polyline points="3,10 8,14 13,10"/></svg></span></th>
                    {% endif %}
                </tr>
            </thead>
            <tbody class="divide-y divide-white/10">
                {% for pick in picks %}
                    <tr class="hover:bg-white/5 transition">
                        <td class="px-4 py-3 text-white/85" data-sort-value="{{ pick.running_order ?? '' }}">{{ pick.running_order ?? '—' }}</td>
                        <td class="px-4 py-3 font-medium text-white" data-sort-value="{{ pick.name }}">
                            {% if pick.flag_image %}
                                <img src="/uploads/flags/{{ pick.flag_image }}" alt="{{ pick.name }}" class="h-auto w-auto mr-2 rounded-sm flex-shrink-0 inline-block align-middle">
                            {% endif %}
                            {{ pick.name }}
                        </td>
                        <td class="px-4 py-3 text-white/85 hidden sm:table-cell" data-sort-value="{{ pick.group_name }}">{{ pick.group_name }}</td>
                        <td class="px-4 py-3 text-right text-white/85" data-sort-value="{{ pick.price }}">€{{ pick.price|number_format(1) }}m</td>
                        {% if is_finished %}
                            <td class="px-4 py-3 text-right text-white/85" data-sort-value="{{ pick.final_score_raw ?? '' }}">
                                {% if pick.final_score_raw is not null %}
                                    {{ pick.final_score_raw }}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="px-4 py-3 text-right font-bold
                                {% if pick.score > 0 %}text-emerald-400
                                {% elseif pick.score < 0 %}text-rose-400
                                {% else %}text-white/70{% endif %}"
                                data-sort-value="{{ pick.score }}">
                                {{ pick.score > 0 ? '+' : '' }}{{ pick.score }}
                            </td>
                        {% endif %}
                    </tr>
                {% endfor %}
            </tbody>
            {% if is_finished %}
                <tfoot>
                    <tr class="bg-white/5 font-bold">
                        <td class="px-4 py-3 text-white/85" colspan="4">Total</td>
                        <td class="px-4 py-3 text-right"></td>
                        <td class="px-4 py-3 text-right text-emerald-400 text-base">{{ total_score }}</td>
                    </tr>
                </tfoot>
            {% endif %}
        </table>
    </div>

    <div class="flex flex-wrap justify-end gap-4 text-sm text-white/85 pr-4">
        <span>Total Spend: <strong class="text-white">€{{ entry.total_cost|number_format(1) }}m</strong></span>
        {% if is_finished %}
            <span>Total score: <strong class="text-emerald-400">{{ total_score }}</strong></span>
        {% endif %}
        {% if contest and contest.status in ['open', 'closed', 'finished'] %}
            <a href="/leaderboard" class="text-fuchsia-400 hover:text-fuchsia-300 hover:underline font-semibold">View Leaderboard →</a>
        {% endif %}
    </div>
{% endblock %}

{% block scripts %}
<script src="/js/my-team.js"></script>
{% endblock %}
