<!DOCTYPE html>
<html lang="en" class="bg-indigo-950 text-white">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ site_name }}{% endblock %}</title>
    <link rel="stylesheet" href="/css/app.css">
</head>
<body class="min-h-screen flex flex-col">

    <nav class="bg-indigo-900 border-b border-indigo-700 px-4 py-3">
        <div class="max-w-5xl mx-auto flex items-center justify-between">
            <a href="/" class="text-yellow-400 font-bold text-xl tracking-wide">🎤 {{ site_name }}</a>

            <div class="flex items-center gap-4 text-sm">
                {% if is_logged_in %}
                    {% if is_admin %}
                        <a href="/admin"
                           class="{% if current_path starts with '/admin' %}text-yellow-400 font-semibold{% else %}text-indigo-300 hover:text-white{% endif %}">
                            CMS
                        </a>
                    {% else %}
                        <a href="/my-team"
                           class="{% if current_path == '/my-team' %}text-yellow-400 font-semibold{% else %}text-indigo-300 hover:text-white{% endif %}">
                            My Team
                        </a>
                        {% if contest and contest.status in ['locked', 'scored'] %}
                            <a href="/leaderboard"
                               class="{% if current_path == '/leaderboard' %}text-yellow-400 font-semibold{% else %}text-indigo-300 hover:text-white{% endif %}">
                                Leaderboard
                            </a>
                        {% endif %}
                    {% endif %}
                    <span class="text-indigo-400">{{ user_name }}</span>
                    <a href="/logout" class="text-indigo-300 hover:text-white">Log out</a>
                {% else %}
                    <a href="/login"
                       class="{% if current_path == '/login' %}text-yellow-400 font-semibold{% else %}text-indigo-300 hover:text-white{% endif %}">
                        Log in
                    </a>
                    <a href="/register"
                       class="{% if current_path == '/register' %}text-yellow-400 font-semibold{% else %}text-indigo-300 hover:text-white{% endif %}">
                        Register
                    </a>
                {% endif %}
            </div>
        </div>
    </nav>

    {% if flash %}
        <div class="max-w-5xl mx-auto w-full px-4 pt-4">
            <div class="rounded-lg px-4 py-3 text-sm font-medium
                {% if flash.type == 'success' %}bg-green-800 text-green-100 border border-green-600
                {% else %}bg-red-800 text-red-100 border border-red-600{% endif %}">
                {{ flash.message }}
            </div>
        </div>
    {% endif %}

    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
        {% block content %}{% endblock %}
    </main>

    <footer class="bg-indigo-900 border-t border-indigo-700 text-center text-indigo-400 text-sm py-4">
        &copy; {{ current_year }} {{ site_name }}
    </footer>

</body>
</html>
