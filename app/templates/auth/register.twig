{% extends 'base.twig' %}

{% block title %}Register — {{ site_name }}{% endblock %}

{% block content %}
    <div class="max-w-md mx-auto">
        <h1 class="text-3xl font-bold text-yellow-400 mb-8 text-center">Create Account</h1>

        {% if errors is defined and errors %}
            <div class="bg-red-900 border border-red-600 rounded-lg px-4 py-3 mb-6">
                {% for error in errors %}
                    <p class="text-red-200 text-sm">{{ error }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form method="POST" action="/register" class="bg-indigo-900 rounded-xl p-6 space-y-5 border border-indigo-700">
            <div>
                <label for="name" class="block text-sm font-medium text-indigo-200 mb-1">Display Name</label>
                <input type="text" id="name" name="name"
                       value="{{ name ?? '' }}"
                       required autocomplete="nickname"
                       class="w-full bg-indigo-950 border border-indigo-600 rounded-lg px-3 py-2 text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-yellow-400">
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-indigo-200 mb-1">Email</label>
                <input type="email" id="email" name="email"
                       value="{{ email ?? '' }}"
                       required autocomplete="email"
                       class="w-full bg-indigo-950 border border-indigo-600 rounded-lg px-3 py-2 text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-yellow-400">
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-indigo-200 mb-1">Password</label>
                <input type="password" id="password" name="password"
                       required autocomplete="new-password" minlength="8"
                       class="w-full bg-indigo-950 border border-indigo-600 rounded-lg px-3 py-2 text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-yellow-400">
                <p class="text-indigo-400 text-xs mt-1">At least 8 characters</p>
            </div>

            <div>
                <label for="password_confirm" class="block text-sm font-medium text-indigo-200 mb-1">Confirm Password</label>
                <input type="password" id="password_confirm" name="password_confirm"
                       required autocomplete="new-password"
                       class="w-full bg-indigo-950 border border-indigo-600 rounded-lg px-3 py-2 text-white placeholder-indigo-400 focus:outline-none focus:ring-2 focus:ring-yellow-400">
            </div>

            <button type="submit"
                    class="w-full bg-yellow-400 hover:bg-yellow-300 text-indigo-950 font-bold py-2 px-4 rounded-lg transition">
                Create Account
            </button>
        </form>

        <p class="text-center text-indigo-400 text-sm mt-4">
            Already have an account?
            <a href="/login" class="text-yellow-400 hover:underline">Log in here</a>
        </p>
    </div>
{% endblock %}
