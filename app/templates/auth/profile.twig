{% extends 'base.twig' %}

{% block title %}Profile | {{ site_name }}{% endblock %}

{% block content %}
    <div class="max-w-md mx-auto">
        <h1 class="text-3xl mt-4 mb-8 text-center">Your Profile</h1>

        {% if errors is defined and errors %}
            <div class="bg-rose-500/20 border border-rose-500/40 rounded-lg px-4 py-3 mb-6">
                {% for error in errors %}
                    <p class="text-rose-300 text-sm">{{ error }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form method="POST" action="/profile" enctype="multipart/form-data"
              class="bg-stage-900 rounded-xl p-6 space-y-5 border border-white/10">

            <input type="hidden" name="remove_avatar" value="" id="remove-avatar-flag">

            {# Avatar #}
            <div class="flex flex-col items-center gap-3">
                {# Image / placeholder #}
                {% if user.avatar %}
                    <img id="avatar-img" src="/uploads/avatars/{{ user.avatar }}" alt="{{ user.name }}"
                         class="w-40 h-40 rounded-full object-cover border-2 border-white/10">
                {% else %}
                    <div id="avatar-placeholder" class="w-40 h-40 rounded-full bg-white/5 border-2 border-white/10 flex items-center justify-center">
                        <svg class="w-20 h-20 text-white/30" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0012 15.75a7.488 7.488 0 00-5.982 2.975m11.963 0a9 9 0 10-11.963 0m11.963 0A8.966 8.966 0 0112 21a8.966 8.966 0 01-5.982-2.275M15 9.75a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <img id="avatar-img" src="" alt="Preview"
                         class="hidden w-40 h-40 rounded-full object-cover border-2 border-fuchsia-500/40">
                {% endif %}

                <input type="file" id="avatar" name="avatar" accept="image/jpeg,image/png,image/gif,image/webp" class="sr-only">

                {# Buttons: Replace + Remove when avatar exists; Add when no avatar #}
                {% if user.avatar %}
                    <div class="flex flex-col items-center gap-2">
                        <label for="avatar"
                               class="cursor-pointer flex items-center gap-1.5 border border-fuchsia-500 bg-fuchsia-500/10 text-fuchsia-300 hover:bg-fuchsia-500/25 hover:border-fuchsia-400 hover:text-fuchsia-200 font-medium py-1.5 px-4 rounded-lg transition text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd" />
                            </svg>
                            Replace
                        </label>
                        <button type="button" id="remove-avatar-btn"
                                class="flex items-center gap-1.5 border border-rose-500 bg-rose-500/10 text-rose-400 hover:bg-rose-500/25 hover:border-rose-400 hover:text-rose-300 font-medium py-1.5 px-4 rounded-lg transition text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                <path fill-rule="evenodd" d="M4 10a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 10Z" clip-rule="evenodd" />
                            </svg>
                            Remove
                        </button>
                    </div>
                {% else %}
                    <div id="add-controls">
                        <label for="avatar"
                               class="cursor-pointer flex items-center gap-1.5 border border-fuchsia-500 bg-fuchsia-500/10 text-fuchsia-300 hover:bg-fuchsia-500/25 hover:border-fuchsia-400 hover:text-fuchsia-200 font-medium py-1.5 px-4 rounded-lg transition text-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                <path d="M10.75 4.75a.75.75 0 0 0-1.5 0v4.5h-4.5a.75.75 0 0 0 0 1.5h4.5v4.5a.75.75 0 0 0 1.5 0v-4.5h4.5a.75.75 0 0 0 0-1.5h-4.5v-4.5Z" />
                            </svg>
                            Add
                        </label>
                    </div>
                    <div id="preview-controls" class="hidden">
                        <div class="flex flex-col items-center gap-2">
                            <label for="avatar"
                                   class="cursor-pointer flex items-center gap-1.5 border border-fuchsia-500 bg-fuchsia-500/10 text-fuchsia-300 hover:bg-fuchsia-500/25 hover:border-fuchsia-400 hover:text-fuchsia-200 font-medium py-1.5 px-4 rounded-lg transition text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                    <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd" />
                                </svg>
                                Replace
                            </label>
                            <button type="button" id="clear-preview-btn"
                                    class="flex items-center gap-1.5 border border-rose-500 bg-rose-500/10 text-rose-400 hover:bg-rose-500/25 hover:border-rose-400 hover:text-rose-300 font-medium py-1.5 px-4 rounded-lg transition text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                                    <path fill-rule="evenodd" d="M4 10a.75.75 0 0 1 .75-.75h10.5a.75.75 0 0 1 0 1.5H4.75A.75.75 0 0 1 4 10Z" clip-rule="evenodd" />
                                </svg>
                                Remove
                            </button>
                        </div>
                    </div>
                {% endif %}

                <p class="text-white/70 text-xs">JPG, PNG, GIF, or WebP<span class="text-white/30 px-1"> | </span>Max 2MB</p>
            </div>

            <hr class="border-white/10">

            {# Display name #}
            <div>
                <div class="flex items-center justify-between mb-1">
                    <label for="name" class="text-sm font-medium text-white/85">Display Name</label>
                    <span id="name-counter" class="text-xs text-white/70"></span>
                </div>
                <input type="text" id="name" name="name"
                       value="{{ name ?? user.name }}"
                       required autocomplete="nickname" maxlength="16"
                       class="w-full bg-stage-950 border border-white/20 rounded-lg px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-fuchsia-500">
            </div>

            {# Email (read-only) #}
            <div>
                <label class="block text-sm font-medium text-white/85 mb-1">Email</label>
                <p class="w-full bg-stage-950 border border-white/10 rounded-lg px-3 py-2 text-white/30">{{ user.email }}</p>
                <p class="text-white/70 text-sm text-center mt-6 mb-2">Avatar and display name shown on leaderboards. <br class="hidden xs:block">Email will not be made public.</p>
            </div>

            <hr class="border-white/10">

            {# Change password #}
            <div>
                <div class="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-1">
                            <label for="new_password" class="text-sm font-medium text-white/85">New Password</label>
                            <span class="text-xs text-white/70">Min 8 characters</span>
                        </div>
                        <div class="relative">
                            <input type="password" id="new_password" name="new_password"
                                   autocomplete="new-password" minlength="8"
                                   class="w-full bg-stage-950 border border-white/20 rounded-lg px-3 py-2 pr-10 text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-fuchsia-500">
                            <button type="button" onclick="togglePassword('new_password', this)"
                                    class="absolute inset-y-0 right-0 flex items-center px-3 text-white/30 hover:text-white/85 transition-colors"
                                    aria-label="Toggle password visibility">
                                <svg class="eye-open w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <svg class="eye-closed w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div>
                        <label for="new_password_confirm" class="block text-sm font-medium text-white/85 mb-1">Confirm New Password</label>
                        <div class="relative">
                            <input type="password" id="new_password_confirm" name="new_password_confirm"
                                   autocomplete="new-password"
                                   class="w-full bg-stage-950 border border-white/20 rounded-lg px-3 py-2 pr-10 text-white placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-fuchsia-500">
                            <button type="button" onclick="togglePassword('new_password_confirm', this)"
                                    class="absolute inset-y-0 right-0 flex items-center px-3 text-white/30 hover:text-white/85 transition-colors"
                                    aria-label="Toggle password visibility">
                                <svg class="eye-open w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                                <svg class="eye-closed w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <p class="text-white/70 text-sm text-center mt-6 mb-2">Leave password fields empty to keep current password.</p>
            </div>

            <div class="pt-5 flex flex-col gap-3">
                <button type="submit"
                        class="w-full bg-gradient-to-r from-fuchsia-500 to-purple-600 hover:from-fuchsia-400 hover:to-purple-500 text-white font-bold py-2 px-4 rounded-lg transition">
                    Save Changes
                </button>
                <a href="/my-team"
                   class="w-full text-center border border-white/20 text-white/85 hover:border-white/40 hover:text-white font-bold py-2 px-4 rounded-lg transition">
                    Cancel
                </a>
            </div>
        </form>

        {# Remove avatar confirmation dialog #}
        <dialog id="remove-avatar-dialog"
                class="bg-stage-900 border border-white/10 rounded-xl shadow-2xl p-6 w-full max-w-sm mx-auto mt-[25vh] backdrop:bg-black/70">
            <h2 class="text-xl mb-2">Remove Avatar</h2>
            <p class="text-white/85 text-sm mb-6">Are you sure? Your current profile picture will be permanently deleted.</p>
            <div class="flex gap-3 justify-end">
                <button type="button" id="remove-avatar-cancel"
                        class="border border-white/20 text-white/85 hover:border-white/40 hover:text-white font-medium py-2 px-4 rounded-lg text-sm transition">
                    Cancel
                </button>
                <button type="button" id="remove-avatar-confirm"
                        class="bg-gradient-to-r from-rose-600 to-rose-700 hover:from-rose-500 hover:to-rose-600 text-white font-bold py-2 px-4 rounded-lg text-sm transition">
                    Remove Avatar
                </button>
            </div>
        </dialog>

    </div>
{% endblock %}

{% block scripts %}
<script src="/js/password-toggle.js"></script>
<script src="/js/profile.js"></script>
<script src="/js/name-counter.js"></script>
{% endblock %}
